# =========================================================================
# ResuMind AI Backend - Environment Configuration
# =========================================================================
# Copy this file to '.env' and replace placeholders with your actual keys.
# =========================================================================

# 🚀 Server Port
PORT=5000

# 🧠 MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/resume_analytics?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/resume_analytics?retryWrites=true&w=majority&appName=Cluster0

# 🔑 JWT Secret (random string for signing auth tokens)
JWT_SECRET=your_random_secret_here

# 🔐 Google OAuth Client ID (for Google Sign-In)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# -------------------------------------------------------------------------
# AI & Large Language Models APIs
# -------------------------------------------------------------------------

# 🤖 OpenRouter API Key (ChatBot widget)
# Get from: https://openrouter.ai/
OPENROUTER_API_KEY=

# 🤖 OpenAI API Key (resume structure parsing)
# Get from: https://platform.openai.com/
OPENAI_API_KEY=

# 🤖 Groq API Key (LLaMA 3 feedback)
# Get from: https://console.groq.com/
GROQ_API_KEY=

# 🤖 Cohere API Key (ATS scoring & skill extraction)
# Get from: https://cohere.com/
COHERE_API_KEY=

# 🤖 Google Gemini API Key (mock interviews)
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=

# -------------------------------------------------------------------------
# Utilities & External Services APIs
# -------------------------------------------------------------------------

# 🎙️ AssemblyAI API Key (audio transcription)
# Get from: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=

# 💼 RapidAPI Key (salary stats & job search)
# Get from: https://rapidapi.com/
RAPIDAPI_KEY=

# 📺 YouTube API Key (learning tutorials)
# Get from: Google Cloud Console
YOUTUBE_API_KEY=

# 🎓 Udemy Credentials (course search)
# Get from: https://www.udemy.com/developers/
UDEMY_CLIENT_ID=
UDEMY_CLIENT_SECRET=
